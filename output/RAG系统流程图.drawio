          <mxGeometry x="40" y="840" width="400" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s6_1" value="[1] 技术文档.pdf - RAG检索增强生成技术..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#90A4AE;align=left;fontSize=10" vertex="1" parent="1">
