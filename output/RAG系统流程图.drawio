          <mxGeometry x="60" y="970" width="360" height="22" as="geometry"/>
        </mxCell>
        <!-- 右侧说明 -->
        <mxCell id="sexp1" value="KNN参数&#xa;- k: 返回Top数&#xa;- numCandidates: 候选数" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;align=left;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="160" height="70" as="geometry"/>
        </mxCell>
