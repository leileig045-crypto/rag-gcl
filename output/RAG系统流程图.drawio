          <mxGeometry x="60" y="895" width="360" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="s6_3" value="[3] FAQ.txt - RAG常见问题解答..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#90A4AE;align=left;fontSize=10" vertex="1" parent="1">
