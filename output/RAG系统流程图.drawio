        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="stitle" value="混合检索流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="300" height="40" as="geometry"/>
        </mxCell>
        <!-- Step 1 -->
        <mxCell id="s1" value="Step 1: 查询向量生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;fontColor=#FFFFFF;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="400" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s1_1" value="用户输入查询&#xa;&quot;如何使用RAG？&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81C784;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="140" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s1_2" value="Embedding&#xa;text-embedding-v4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#81C784;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="260" y="110" width="140" height="45" as="geometry"/>
        </mxCell>
        <!-- Step 2 -->
        <mxCell id="s2" value="Step 2: KNN向量检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="s2_1" value="ES KNN Query&#xa;k=150, candidates=150" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#64B5F6;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s2_2" value="向量相似度召回Top-150" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;align=center;fontColor=#1565C0" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="320" height="25" as="geometry"/>
        </mxCell>
        <!-- Step 3 -->
        <mxCell id="s3" value="Step 3: BM25过滤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#FFFFFF;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="400" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s3_1" value="must: match textContent&#xa;query: RAG技术" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFB74D;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s3_2" value="关键词必须命中" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;align=center;fontColor=#E65100" vertex="1" parent="1">
          <mxGeometry x="80" y="465" width="320" height="20" as="geometry"/>
        </mxCell>
        <!-- Step 4 -->
        <mxCell id="s4" value="Step 4: 权限过滤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;fontColor=#FFFFFF;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="s4_1" value="should: userId (我的文档)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BA68C8;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="s4_2" value="should: public (公开)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BA68C8;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="240" y="560" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="s4_3" value="should: orgTag (组织)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BA68C8;fontColor=#FFFFFF;align=center" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="s4_4" value="三选一满足即可" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;align=center;fontColor=#6A1B9A" vertex="1" parent="1">
          <mxGeometry x="240" y="615" width="150" height="25" as="geometry"/>
        </mxCell>
        <!-- Step 5 -->
