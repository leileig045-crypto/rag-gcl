        <mxCell id="sexp3" value="权限说明&#xa;- PRIVATE_*: 仅创建者&#xa;- orgTag: 同组织&#xa;- DEFAULT: 所有用户" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;align=left;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="480" y="560" width="160" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Elasticsearch索引结构" id="es-index">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
